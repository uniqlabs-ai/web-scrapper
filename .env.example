# Finance Module — Environment Variables

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/finance"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Founder OS Orchestrator (Heartbeat Protocol)
ORCHESTRATOR_URL="http://localhost:4000"
WEBHOOK_SECRET="your-webhook-secret"

# Email (Resend)
RESEND_API_KEY=""
RESEND_DOMAIN="finance.founderOS.app"

# ==========================================
# PHASE 7 ADDITIONS: THE LIVE FIAT ENGINES
# ==========================================

# 1. AI A/P INBOX
GEMINI_API_KEY="your-gemini-2-flash-api-key"

# 2. VIRTUAL CFO / MRR (Stripe)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# 3. GLOBAL PAYOUTS & PAYROLL (RazorpayX)
RAZORPAYX_KEY_ID="rzp_test_..."
RAZORPAYX_KEY_SECRET="your-razorpayx-secret"

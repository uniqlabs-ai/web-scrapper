generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
}

model Organization {
  id            String   @id @default(uuid())
  name          String
  currency      String   @default("INR")
  cashInBank    Decimal  @default(0) @db.Decimal(15, 2)
  gstNumber     String?
  address       String?  @db.Text
  logoUrl       String?
  alertSettings String?  @db.Text
  
  // Multi-Entity Parent/Child Hierarchy
  type          String   @default("independent") // independent | hq | subsidiary
  parentId      String?
  parent        Organization?  @relation("OrgHierarchy", fields: [parentId], references: [id])
  subsidiaries  Organization[] @relation("OrgHierarchy")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // SaaS Billing
  planTier        String    @default("free") // free | starter | professional | enterprise
  razorpayId      String?   @unique
  subscriptionId  String?
  trialEndsAt     DateTime?
  
  // Customization
  brandColor      String?   @default("#0f172a")
  knowledgeBase   String?   @db.Text
  domainWhitelist String?   @db.Text // Comma-separated domains allowed to embed via iframe

  users      User[]
  clients    Client[]
  invoices   Invoice[]
  expenses   Expense[]
  revenues   Revenue[]
  accounts   Account[]
  categories ExpenseCategory[]
  budgets    BudgetThreshold[]
  vendors    Vendor[]
  recurringExpenses RecurringExpense[]
  employees  Employee[]
  payrollRuns PayrollRun[]
  
  apiKeys    ApiKey[]
  webhooks   Webhook[]
}

model ApiKey {
  id             String       @id @default(uuid())
  name           String
  keyHash        String       @unique
  lastUsedAt     DateTime?
  createdAt      DateTime     @default(now())
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Webhook {
  id             String       @id @default(uuid())
  url            String
  events         String       @db.Text // JSON array e.g. ["invoice.created"]
  secret         String
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Employee {
  id              String   @id @default(uuid())
  employeeId      String   @unique       // EMP-001
  name            String
  email           String?
  phone           String?
  designation     String?
  department      String?
  joinDate        DateTime @default(now())
  panNumber       String?
  uanNumber       String?               // PF UAN
  bankAccount     String?
  bankIfsc        String?
  isActive        Boolean  @default(true)
  type            String   @default("employee")  // "employee" | "contractor"
  paymentBasis    String?  // "fixed" | "milestone" | "hourly"
  aliases         String?  @db.Text              // JSON array of alternate bank names

  // Salary Structure (monthly)
  basicSalary     Decimal  @db.Decimal(12, 2)
  hra             Decimal  @default(0) @db.Decimal(12, 2)
  da              Decimal  @default(0) @db.Decimal(12, 2)
  specialAllowance Decimal @default(0) @db.Decimal(12, 2)
  otherAllowance  Decimal  @default(0) @db.Decimal(12, 2)
  ctc             Decimal  @db.Decimal(12, 2)      // Annual CTC

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  payrollRuns     PayrollRun[]
}

model PayrollRun {
  id              String   @id @default(uuid())
  month           String                // "2026-03"
  runDate         DateTime @default(now())
  status          String   @default("draft")  // draft | processed | paid

  employeeId      String
  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Earnings
  basicPay        Decimal  @db.Decimal(12, 2)
  hraPay          Decimal  @default(0) @db.Decimal(12, 2)
  daPay           Decimal  @default(0) @db.Decimal(12, 2)
  specialPay      Decimal  @default(0) @db.Decimal(12, 2)
  otherPay        Decimal  @default(0) @db.Decimal(12, 2)
  grossPay        Decimal  @db.Decimal(12, 2)

  // Deductions
  pfEmployee      Decimal  @default(0) @db.Decimal(12, 2)  // 12% of basic
  pfEmployer      Decimal  @default(0) @db.Decimal(12, 2)  // 12% of basic (company cost)
  esiEmployee     Decimal  @default(0) @db.Decimal(12, 2)  // 0.75% if gross < 21000
  esiEmployer     Decimal  @default(0) @db.Decimal(12, 2)  // 3.25%
  professionalTax Decimal  @default(0) @db.Decimal(12, 2)  // state-wise
  tds             Decimal  @default(0) @db.Decimal(12, 2)
  otherDeductions Decimal  @default(0) @db.Decimal(12, 2)
  totalDeductions Decimal  @db.Decimal(12, 2)

  netPay          Decimal  @db.Decimal(12, 2)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  fullName  String?
  avatarUrl String?
  role      String   @default("admin")  // admin | accountant | viewer | custom
  permissions String? @db.Text          // JSON array of accessible modules e.g. ["invoices", "expenses"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  invoices   Invoice[]
  expenses   Expense[]
  revenues   Revenue[]
  accounts   Account[]
  clients    Client[]
  categories         ExpenseCategory[]
  bankAccounts       BankAccount[]
  bankTransactions   BankTransaction[]
  importBatches      ImportBatch[]
  vendors            Vendor[]
  recurringExpenses  RecurringExpense[]
  payments           Payment[]
  employees          Employee[]
  payrollRuns        PayrollRun[]
  receipts           Receipt[]
  activityLogs       ActivityLog[]
  approvals          ExpenseApproval[]
  integrations       Integration[]
  auditLogs          AuditLog[]
}

model Account {
  id             String   @id @default(uuid())
  name           String
  type           String   @default("bank")
  currentBalance Decimal  @default(0) @db.Decimal(15, 2)
  currency       String   @default("INR")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  expenses       Expense[]
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  company   String?
  gstNumber String?
  address   String?  @db.Text
  displayName String?             // Short nickname for long billing names
  aliases     String?  @db.Text   // JSON array of alternate names in bank
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  invoices       Invoice[]
  revenues       Revenue[]
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String
  status        String   @default("draft")
  issueDate     DateTime @default(now())
  dueDate       DateTime
  subtotal      Decimal  @default(0) @db.Decimal(15, 2)
  taxTotal      Decimal  @default(0) @db.Decimal(15, 2)
  total         Decimal  @default(0) @db.Decimal(15, 2)
  currency      String   @default("INR")
  notes         String?  @db.Text

  gstNumber     String?
  placeOfSupply String?
  isInterState  Boolean  @default(false)

  paidAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization?    @relation(fields: [organizationId], references: [id])
  clientId       String?
  client         Client?          @relation(fields: [clientId], references: [id])
  lineItems      InvoiceLineItem[]
  payments       Payment[]
}

model InvoiceLineItem {
  id          String   @id @default(uuid())
  description String
  quantity    Decimal  @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal  @db.Decimal(15, 2)
  amount      Decimal  @db.Decimal(15, 2)
  gstRate     Decimal  @default(0) @db.Decimal(5, 2)
  cgst        Decimal  @default(0) @db.Decimal(15, 2)
  sgst        Decimal  @default(0) @db.Decimal(15, 2)
  igst        Decimal  @default(0) @db.Decimal(15, 2)
  total       Decimal  @db.Decimal(15, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  name      String
  icon      String?
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  expenses       Expense[]

  @@unique([userId, name])
}

model Expense {
  id          String   @id @default(uuid())
  description String
  amount      Decimal  @db.Decimal(15, 2)
  currency    String   @default("INR")
  date        DateTime @default(now())
  vendor      String?
  receipt     String?
  notes       String?  @db.Text
  isRecurring Boolean  @default(false)
  source      String?
  sourceId    String?
  department  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization?    @relation(fields: [organizationId], references: [id])
  categoryId     String?
  category       ExpenseCategory? @relation(fields: [categoryId], references: [id])
  vendorId       String?
  vendorEntity   Vendor?          @relation(fields: [vendorId], references: [id])
  accountId      String?
  account        Account?         @relation(fields: [accountId], references: [id])
  receipts       Receipt[]
  approvals      ExpenseApproval[]
}

model Revenue {
  id         String   @id @default(uuid())
  month      DateTime
  amount     Decimal  @db.Decimal(15, 2)
  currency   String   @default("INR")
  type       String   @default("recurring")
  category   String?
  source     String?
  sourceId   String?
  notes      String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  clientId       String?
  client         Client?       @relation(fields: [clientId], references: [id])
}

model BudgetThreshold {
  id             String   @id @default(uuid())
  category       String
  monthlyLimit   Decimal  @db.Decimal(15, 2)
  alertAt        Decimal  @default(0.8) @db.Decimal(3, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model BankAccount {
  id               String   @id @default(uuid())
  name             String
  bankName         String?
  accountNumber    String?
  accountLast4     String?             // Last 4 digits — used for Gmail transaction matching
  accountType      String   @default("savings")  // savings | current | overdraft | cc | other
  ifscCode         String?
  bankEmailDomains String?  @db.Text   // Comma-separated sender domains e.g. "icicibank.com,icici"
  currentBalance   Decimal  @default(0) @db.Decimal(15, 2)
  currency         String   @default("INR")
  isActive         Boolean  @default(true)
  lastSyncAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  transactions   BankTransaction[]
}

model BankTransaction {
  id              String   @id @default(uuid())
  date            DateTime
  description     String
  reference       String?
  amount          Decimal  @db.Decimal(15, 2)
  type            String   @default("debit")  // debit | credit
  balance         Decimal? @db.Decimal(15, 2)
  category        String?
  vendor          String?
  notes           String?  @db.Text
  isReconciled    Boolean  @default(false)
  confidence      Decimal? @db.Decimal(3, 2)   // AI categorization confidence 0-1
  source          String   @default("csv")     // csv | ofx | aa | manual
  importBatchId   String?
  matchedExpenseId String?
  matchedInvoiceId String?
  hash            String?  @unique            // dedup hash
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bankAccountId  String
  bankAccount    BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  importBatch    ImportBatch? @relation(fields: [importBatchId], references: [id])
}

model ImportBatch {
  id            String   @id @default(uuid())
  type          String            // bank_csv | expense_csv | revenue_csv | financial_statement
  fileName      String
  rowCount      Int      @default(0)
  status        String   @default("pending")  // pending | processing | completed | failed
  errorMessage  String?  @db.Text
  columnMapping String?  @db.Text  // JSON string of column mappings
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions  BankTransaction[]
}

model Payment {
  id            String   @id @default(uuid())
  amount        Decimal  @db.Decimal(15, 2)
  date          DateTime @default(now())
  method        String   @default("bank_transfer") // bank_transfer | upi | cash | cheque | card
  reference     String?                            // UTR, UPI ref, cheque number
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vendor {
  id            String   @id @default(uuid())
  name          String
  email         String?
  phone         String?
  company       String?
  gstNumber     String?
  panNumber     String?
  bankName      String?
  bankAccount   String?
  bankIfsc      String?
  paymentTerms  Int      @default(30)  // days
  address       String?  @db.Text
  notes         String?  @db.Text
  isActive      Boolean  @default(true)
  aliases       String?  @db.Text   // JSON array of alternate bank names
  displayName   String?             // Clean display name
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  expenses       Expense[]

  @@unique([userId, name])
}

model RecurringExpense {
  id          String   @id @default(uuid())
  description String
  amount      Decimal  @db.Decimal(15, 2)
  currency    String   @default("INR")
  frequency   String   @default("monthly") // monthly | quarterly | yearly | weekly
  startDate   DateTime @default(now())
  endDate     DateTime?
  nextDueDate DateTime
  lastCreated DateTime?
  isActive    Boolean  @default(true)
  vendor      String?
  categoryId  String?
  notes       String?  @db.Text
  aliases     String?  @db.Text   // JSON array: ["OpenAI Chat", "OPENAI CHA"]
  bucketName  String?             // Group name: "Commission" groups CGST+SGST+base
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
}

model Receipt {
  id             String   @id @default(uuid())
  fileName       String
  mimeType       String   @default("image/jpeg")
  imageData      String   @db.Text               // base64-encoded image
  status         String   @default("pending")     // pending | processed | failed
  confidence     Decimal? @db.Decimal(3, 2)       // OCR confidence 0-1

  // Extracted fields (JSON)
  extractedData  String?  @db.Text               // full JSON from OCR
  extractedAmount   Decimal? @db.Decimal(15, 2)
  extractedVendor   String?
  extractedDate     DateTime?
  extractedGst      String?                      // GST number from receipt
  extractedCategory String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenseId      String?
  expense        Expense? @relation(fields: [expenseId], references: [id])
}

model ActivityLog {
  id          String   @id @default(uuid())
  action      String                          // created | updated | deleted | approved | rejected | sent
  resource    String                          // expense | invoice | vendor | receipt | budget | payroll
  resourceId  String?
  metadata    String?  @db.Text              // JSON with details
  ipAddress   String?
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ExpenseApproval {
  id          String   @id @default(uuid())
  status      String   @default("pending")   // pending | approved | rejected
  comments    String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenseId   String
  expense     Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  approverId  String
  approver    User     @relation(fields: [approverId], references: [id], onDelete: Cascade)
}

model Integration {
  id           String    @id @default(uuid())
  type         String    // "gmail", "plaid", "bank_api"
  status       String    @default("disconnected") // disconnected | connected | error
  accessToken  String?   @db.Text
  refreshToken String?   @db.Text
  lastSyncAt   DateTime?
  syncCount    Int       @default(0)
  metadata     String?   @db.Text // JSON: email, scopes, bank name, etc.
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String   // "create", "update", "delete", "import", "export", "login"
  resource    String   // "invoice", "expense", "vendor", "client", "employee", "recurring", "bank_transaction", "revenue"
  resourceId  String?  // ID of affected resource
  details     String?  @db.Text // JSON with extra context
  ipAddress   String?
  createdAt   DateTime @default(now())

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([resource, action])
}
